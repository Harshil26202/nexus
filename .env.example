# ─── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
JWT_SECRET=change_me_in_production_use_256bit_random

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_secret
DATABASE_URL=postgresql+asyncpg://nexus:nexus_secret@localhost:5432/nexus

# ─── Cache ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379/0

# ─── OpenAI  (required — get yours at platform.openai.com) ───────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MINI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ─── Azure OpenAI (optional — fills in OPENAI_* when both endpoint + key set) ─
# Leave blank to use standard OpenAI above instead.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_MINI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ─── Azure AI Search (optional — enables semantic code/incident search) ───────
AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_KEY=
AZURE_AI_SEARCH_INDEX_CODE=nexus-code-embeddings
AZURE_AI_SEARCH_INDEX_INCIDENTS=nexus-incidents
AZURE_AI_SEARCH_INDEX_TESTS=nexus-test-history

# ─── Azure Service Bus (optional — enables async agent task queue) ────────────
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_QUEUE_PIPELINE=nexus-pipeline-events
AZURE_SERVICE_BUS_QUEUE_INCIDENTS=nexus-incident-events
AZURE_SERVICE_BUS_QUEUE_AGENTS=nexus-agent-tasks

# ─── Azure Application Insights (optional — distributed tracing) ─────────────
AZURE_APPINSIGHTS_CONNECTION_STRING=

# ─── Azure Entra ID (optional — SSO for the dashboard) ──────────────────────
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ─── GitHub App (optional — enables real webhook processing) ─────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=nexus_dev_secret
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Azure Blob Storage (optional — artifact storage) ────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_ARTIFACTS=nexus-artifacts
AZURE_STORAGE_CONTAINER_LOGS=nexus-logs

# ─── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=nexus-backend
GRAFANA_PASSWORD=admin

# ─── Notifications (optional) ─────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
PAGERDUTY_API_KEY=
PAGERDUTY_SERVICE_ID=
MICROSOFT_TEAMS_WEBHOOK_URL=

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXTAUTH_SECRET=change_me_in_production
NEXTAUTH_URL=http://localhost:3000
