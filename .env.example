# ─── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
JWT_SECRET=change_me_in_production_use_256bit_random

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_secret
DATABASE_URL=postgresql+asyncpg://nexus:nexus_secret@localhost:5432/nexus

# ─── Cache ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379/0

# ─── Azure AI Foundry (GPT-4o) ────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_MINI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ─── Azure AI Search (Vector Store) ──────────────────────────────────────────
AZURE_AI_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_AI_SEARCH_KEY=<your-search-key>
AZURE_AI_SEARCH_INDEX_CODE=nexus-code-embeddings
AZURE_AI_SEARCH_INDEX_INCIDENTS=nexus-incidents
AZURE_AI_SEARCH_INDEX_TESTS=nexus-test-history

# ─── Azure Service Bus ────────────────────────────────────────────────────────
AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=...
AZURE_SERVICE_BUS_QUEUE_PIPELINE=nexus-pipeline-events
AZURE_SERVICE_BUS_QUEUE_INCIDENTS=nexus-incident-events
AZURE_SERVICE_BUS_QUEUE_AGENTS=nexus-agent-tasks

# ─── Azure Application Insights ───────────────────────────────────────────────
AZURE_APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=...

# ─── Azure Entra ID (Auth) ────────────────────────────────────────────────────
AZURE_AD_CLIENT_ID=<your-app-client-id>
AZURE_AD_CLIENT_SECRET=<your-app-client-secret>
AZURE_AD_TENANT_ID=<your-tenant-id>

# ─── GitHub App ───────────────────────────────────────────────────────────────
GITHUB_APP_ID=<your-github-app-id>
GITHUB_APP_PRIVATE_KEY=<path-or-base64-encoded-pem>
GITHUB_WEBHOOK_SECRET=<your-webhook-secret>
GITHUB_CLIENT_ID=<github-oauth-client-id>
GITHUB_CLIENT_SECRET=<github-oauth-client-secret>

# ─── Azure Blob Storage ───────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER_ARTIFACTS=nexus-artifacts
AZURE_STORAGE_CONTAINER_LOGS=nexus-logs

# ─── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=nexus-backend
GRAFANA_PASSWORD=admin

# ─── Notifications ────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
PAGERDUTY_API_KEY=<pagerduty-api-key>
PAGERDUTY_SERVICE_ID=<pagerduty-service-id>
MICROSOFT_TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXTAUTH_SECRET=change_me_in_production
NEXTAUTH_URL=http://localhost:3000
